      </div>

      <!-- Table of Contents -->
      <div class="bg-gray-50 rounded-xl p-6 mb-12 border border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">📋 Complete Guide Contents</h2>
        <nav class="grid grid-cols-1 md:grid-cols-2 gap-2">
          <a href="#what-is-proprofs" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">1. What is ProProfs Chat?</a>
          <a href="#key-features" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">2. Key Features & Capabilities</a>
          <a href="#ai-features" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">3. AI-Powered Features</a>
          <a href="#pricing-plans" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">4. Pricing Plans & Value Analysis</a>
          <a href="#competitor-comparison" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">5. vs Competitors (Intercom, Zendesk, LiveChat)</a>
          <a href="#implementation-guide" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">6. Implementation Guide</a>
          <a href="#case-studies" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">7. Real-World Case Studies</a>
          <a href="#pros-cons" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">8. Pros & Cons Analysis</a>
          <a href="#alternatives" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">9. Best Alternatives</a>
          <a href="#final-verdict" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">10. Final Verdict & Recommendations</a>
        </nav>
