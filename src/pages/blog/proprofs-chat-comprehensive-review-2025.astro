          <a href="#customer-support" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">6. Customer Support and Training</a>
          <a href="#security" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">7. Security and Compliance</a>
          <a href="#success-stories" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">8. Real-World Success Stories</a>
          <a href="#advantages" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">9. Advantages and Considerations</a>
          <a href="#who-should-choose" class="block text-primary-600 hover:text-primary-700 text-sm transition-colors">10. Who Should Choose ProProfs?</a>
        </nav>
      </div>

      <!-- Quick Summary -->
      <div class="bg-white rounded-xl shadow-lg border border-gray-200 p-8 mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">📋 Quick Summary</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="font-semibold text-gray-900 mb-4">✅ Key Strengths</h3>
