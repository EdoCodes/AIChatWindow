                alt="Google Bard AI interface on computer screen"
                class="w-24 h-24 rounded-lg object-cover"
              />
            </div>
            <div class="flex-1">
              <div class="flex items-center space-x-3 mb-3">
                <h3 class="text-2xl font-bold text-gray-900">1. Google Bard</h3>
                <span class="px-3 py-1 bg-green-100 text-green-800 text-xs font-medium rounded-full">100% Free</span>
                <span class="px-3 py-1 bg-blue-100 text-blue-800 text-xs font-medium rounded-full">Real-time Data</span>
              </div>
              
              <p class="text-lg font-medium text-primary-600 mb-4">Best for: Research, creative writing, and real-time information</p>
              
