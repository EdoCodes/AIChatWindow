const tocItems = [
  { id: 'ai-revolution', label: '1. The AI Revolution Continues' },
  { id: 'major-trends', label: '2. Major Trends Shaping 2025' },
  { id: 'technological-breakthroughs', label: '3. Technological Breakthroughs Expected' },
