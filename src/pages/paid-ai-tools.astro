---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Paid AI Tools - AIChatWindow">
  <Header />
  
  <main class="min-h-screen bg-gradient-to-br from-gray-50 to-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16">
      
      <!-- Page Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">
          Premium AI Tools
        </h1>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Advanced AI capabilities with premium features, enhanced performance, 
          and priority support. Perfect for professionals and power users.
        </p>
      </div>

      <!-- Premium Tools Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        
        <!-- ChatGPT Plus -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="relative">
            <img src="https://images.pexels.com/photos/8386440/pexels-photo-8386440.jpeg?auto=compress&cs=tinysrgb&w=400&h=200&fit=crop" alt="ChatGPT Plus" class="w-full h-48 object-cover">
            <div class="absolute top-3 right-3 flex gap-2">
              <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-medium rounded-full">
                Premium
              </span>
              <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs font-medium rounded-full">
                Popular
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-2">ChatGPT Plus</h3>
            <p class="text-gray-600 text-sm mb-4">
              Access to GPT-4, faster response times, and priority access during peak times.
            </p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-gray-900">$20/month</span>
              <a href="https://chat.openai.com/auth/login" target="_blank" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                Subscribe
              </a>
            </div>
          </div>
        </div>

        <!-- Claude Pro -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="relative">
            <img src="https://images.pexels.com/photos/3861969/pexels-photo-3861969.jpeg?auto=compress&cs=tinysrgb&w=400&h=200&fit=crop" alt="Claude Pro" class="w-full h-48 object-cover">
            <div class="absolute top-3 right-3">
              <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-medium rounded-full">
                Premium
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-2">Claude Pro</h3>
            <p class="text-gray-600 text-sm mb-4">
              5x more usage, priority bandwidth, and early access to new features from Anthropic.
            </p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-gray-900">$20/month</span>
              <a href="https://claude.ai/upgrade" target="_blank" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                Subscribe
              </a>
            </div>
          </div>
        </div>

        <!-- Jasper AI -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="relative">
            <img src="https://images.pexels.com/photos/590020/pexels-photo-590020.jpeg?auto=compress&cs=tinysrgb&w=400&h=200&fit=crop" alt="Jasper AI" class="w-full h-48 object-cover">
            <div class="absolute top-3 right-3 flex gap-2">
              <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-medium rounded-full">
                Premium
              </span>
              <span class="px-2 py-1 bg-orange-100 text-orange-800 text-xs font-medium rounded-full">
                Business
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-2">Jasper AI</h3>
            <p class="text-gray-600 text-sm mb-4">
              AI writing assistant for marketing copy, content creation, and business communications.
            </p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-gray-900">$49/month</span>
              <a href="https://jasper.ai/pricing" target="_blank" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                Subscribe
              </a>
            </div>
          </div>
        </div>

        <!-- Copy.ai -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="relative">
            <img src="https://images.pexels.com/photos/8386434/pexels-photo-8386434.jpeg?auto=compress&cs=tinysrgb&w=400&h=200&fit=crop" alt="Copy.ai" class="w-full h-48 object-cover">
            <div class="absolute top-3 right-3">
              <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-medium rounded-full">
                Premium
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-2">Copy.ai</h3>
            <p class="text-gray-600 text-sm mb-4">
              AI-powered copywriting tool for marketing campaigns, social media, and sales content.
            </p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-gray-900">$36/month</span>
              <a href="https://copy.ai/pricing" target="_blank" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                Subscribe
              </a>
            </div>
          </div>
        </div>

        <!-- Replika Pro -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="relative">
            <img src="https://images.pexels.com/photos/3861969/pexels-photo-3861969.jpeg?auto=compress&cs=tinysrgb&w=400&h=200&fit=crop" alt="Replika Pro" class="w-full h-48 object-cover">
            <div class="absolute top-3 right-3 flex gap-2">
              <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-medium rounded-full">
                Premium
              </span>
              <span class="px-2 py-1 bg-pink-100 text-pink-800 text-xs font-medium rounded-full">
                Personal
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-2">Replika Pro</h3>
            <p class="text-gray-600 text-sm mb-4">
              Advanced AI companion with voice calls, AR features, and personalized experiences.
            </p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-gray-900">$20/month</span>
              <a href="https://replika.ai/pricing" target="_blank" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                Subscribe
              </a>
            </div>
          </div>
        </div>

        <!-- Character.AI Plus -->
        <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="relative">
            <img src="https://images.pexels.com/photos/590020/pexels-photo-590020.jpeg?auto=compress&cs=tinysrgb&w=400&h=200&fit=crop" alt="Character.AI Plus" class="w-full h-48 object-cover">
            <div class="absolute top-3 right-3 flex gap-2">
              <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-medium rounded-full">
                Premium
              </span>
              <span class="px-2 py-1 bg-pink-100 text-pink-800 text-xs font-medium rounded-full">
                Creative
              </span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg text-gray-900 mb-2">Character.AI Plus</h3>
            <p class="text-gray-600 text-sm mb-4">
              Priority access, faster responses, and exclusive character creation features.
            </p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-gray-900">$10/month</span>
              <a href="https://character.ai/pricing" target="_blank" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
                Subscribe
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Pricing Comparison -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Premium Features Comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-3 px-4 font-semibold text-gray-900">Feature</th>
                <th class="text-center py-3 px-4 font-semibold text-gray-900">Free</th>
                <th class="text-center py-3 px-4 font-semibold text-gray-900">Premium</th>
                <th class="text-center py-3 px-4 font-semibold text-gray-900">Enterprise</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 text-gray-700">Response Speed</td>
                <td class="py-3 px-4 text-center text-gray-500">Standard</td>
                <td class="py-3 px-4 text-center text-green-600">Fast</td>
                <td class="py-3 px-4 text-center text-green-600">Fastest</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 text-gray-700">Usage Limits</td>
                <td class="py-3 px-4 text-center text-gray-500">Limited</td>
                <td class="py-3 px-4 text-center text-green-600">5x More</td>
                <td class="py-3 px-4 text-center text-green-600">Unlimited</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 text-gray-700">Advanced Models</td>
                <td class="py-3 px-4 text-center text-red-500">✗</td>
                <td class="py-3 px-4 text-center text-green-600">✓</td>
                <td class="py-3 px-4 text-center text-green-600">✓</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 text-gray-700">Priority Support</td>
                <td class="py-3 px-4 text-center text-red-500">✗</td>
                <td class="py-3 px-4 text-center text-green-600">✓</td>
                <td class="py-3 px-4 text-center text-green-600">✓</td>
              </tr>
              <tr>
                <td class="py-3 px-4 text-gray-700">Custom Integration</td>
                <td class="py-3 px-4 text-center text-red-500">✗</td>
                <td class="py-3 px-4 text-center text-red-500">✗</td>
                <td class="py-3 px-4 text-center text-green-600">✓</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Premium Benefits -->
      <div class="bg-gradient-to-r from-primary-500 to-secondary-500 rounded-xl p-8 text-white text-center">
        <h2 class="text-2xl font-bold mb-4">Why Upgrade to Premium?</h2>
        <p class="text-lg opacity-90 mb-6 max-w-2xl mx-auto">
          Unlock the full potential of AI with premium features, faster responses, 
          and priority access to the latest models.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
          <div class="bg-white bg-opacity-10 rounded-lg p-4">
            <h3 class="font-semibold mb-2">Faster Responses</h3>
            <p class="text-sm opacity-80">Get answers up to 5x faster than free users</p>
          </div>
          <div class="bg-white bg-opacity-10 rounded-lg p-4">
            <h3 class="font-semibold mb-2">Advanced Models</h3>
            <p class="text-sm opacity-80">Access to GPT-4, Claude 2, and latest AI models</p>
          </div>
          <div class="bg-white bg-opacity-10 rounded-lg p-4">
            <h3 class="font-semibold mb-2">Priority Support</h3>
            <p class="text-sm opacity-80">24/7 dedicated support for premium users</p>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>