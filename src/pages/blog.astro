---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/blog/BlogCard.astro';

const blogPosts = [
  {
    slug: 'proprofs-chat-comprehensive-review-2025',
    title: 'ProProfs Chat Review 2025: Complete Enterprise Live Chat Solution',
    excerpt: 'Comprehensive review of ProProfs Chat - the enterprise live chat platform trusted by 1M+ businesses. Features, pricing, AI capabilities, and competitor comparisons.',
    date: '2025-01-20',
    readTime: '18 min read',
    category: 'Enterprise Tools',
    image: 'https://images.pexels.com/photos/3184465/pexels-photo-3184465.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop',
    author: 'AIChatWindow Team'
  },
  {
    slug: 'best-free-ai-chatbots-2025',
    title: 'Best Free AI Chatbots in 2025: Complete Guide',
    excerpt: 'Discover the top free AI chatbots available in 2025. Compare features, capabilities, and find the perfect AI assistant for your needs without spending a dime.',
    date: '2025-01-15',
    readTime: '8 min read',
    category: 'Free Tools',
    image: 'https://images.pexels.com/photos/8386440/pexels-photo-8386440.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop',
    author: 'AIChatWindow Team'
  },
  {
    slug: 'chatgpt-vs-claude-vs-bard-comparison',
    title: 'ChatGPT vs Claude vs Bard: Ultimate AI Comparison 2025',
    excerpt: 'In-depth comparison of the three leading AI chatbots. We test ChatGPT, Claude, and Google Bard across multiple categories to help you choose the best AI assistant.',
    date: '2025-01-12',
    readTime: '12 min read',
    category: 'Comparisons',
    image: 'https://images.pexels.com/photos/3861969/pexels-photo-3861969.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop',
    author: 'AIChatWindow Team'
  },
  {
    slug: 'enterprise-ai-chatbot-implementation-guide',
    title: 'Enterprise AI Chatbot Implementation: Complete Guide',
    excerpt: 'Learn how to successfully implement AI chatbots in enterprise environments. Best practices, security considerations, and ROI optimization strategies.',
    date: '2025-01-10',
    readTime: '15 min read',
    category: 'Enterprise',
    image: 'https://images.pexels.com/photos/590020/pexels-photo-590020.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop',
    author: 'AIChatWindow Team'
  },
  {
    slug: 'ai-chatbot-privacy-security-guide',
    title: 'AI Chatbot Privacy & Security: What You Need to Know',
    excerpt: 'Comprehensive guide to AI chatbot privacy and security. Learn how to protect your data when using AI assistants and choose privacy-focused alternatives.',
    date: '2025-01-08',
    readTime: '10 min read',
    category: 'Security',
    image: 'https://images.pexels.com/photos/8386434/pexels-photo-8386434.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop',
    author: 'AIChatWindow Team'
  },
  {
    slug: 'future-of-ai-chatbots-2025-predictions',
    title: 'The Future of AI Chatbots: 2025 Predictions and Trends',
    excerpt: 'Explore the future of AI chatbots with expert predictions for 2025. Discover emerging trends, new technologies, and what to expect from AI assistants.',
    date: '2025-01-05',
    readTime: '9 min read',
    category: 'Trends',
    image: 'https://images.pexels.com/photos/3861969/pexels-photo-3861969.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop',
    author: 'AIChatWindow Team'
  },
  {
    slug: 'how-to-choose-right-ai-chatbot',
    title: 'How to Choose the Right AI Chatbot for Your Needs',
    excerpt: 'Step-by-step guide to selecting the perfect AI chatbot. Compare features, pricing, and use cases to make an informed decision.',
    date: '2025-01-03',
    readTime: '11 min read',
    category: 'Guides',
    image: 'https://images.pexels.com/photos/590020/pexels-photo-590020.jpeg?auto=compress&cs=tinysrgb&w=800&h=400&fit=crop',
    author: 'AIChatWindow Team'
  }
];

const categories = ['All', 'Free Tools', 'Comparisons', 'Enterprise', 'Security', 'Trends', 'Guides'];
---

<Layout title="AI Chatbot Blog - Latest News, Reviews & Guides | AIChatWindow">
  <Header />
  
  <main class="min-h-screen bg-gradient-to-br from-gray-50 to-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16">
      
      <!-- Blog Header - Redesigned -->
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary-600 via-primary-700 to-accent-600 p-10 md:p-14 mb-14 text-white shadow-xl">
        <div class="relative z-10">
          <span class="inline-block px-4 py-1.5 bg-white/25 rounded-full text-sm font-bold mb-4 backdrop-blur-sm border border-white/30">✨ News & Guides</span>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">
            AI Chatbot Blog
          </h1>
          <p class="text-lg md:text-xl text-primary-100 max-w-2xl leading-relaxed">
            Latest AI chatbot news, in-depth reviews, comparisons, and expert guides 
            to help you navigate the world of artificial intelligence.
          </p>
        </div>
        <div class="absolute -right-10 -bottom-10 w-64 h-64 bg-white/10 rounded-full blur-3xl" aria-hidden="true"></div>
      </div>

      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {categories.map(category => (
          <button 
            class={`px-6 py-3 rounded-full text-sm font-medium transition-all duration-200 ${
              category === 'All' 
                ? 'bg-black text-white' 
                : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-100'
            }`}
            onclick={`filterPosts('${category}')`}
          >
            {category}
          </button>
        ))}
      </div>

      <!-- Featured Post -->
      <div class="mb-16">
        <BlogCard
          slug={blogPosts[0].slug}
          title={blogPosts[0].title}
          excerpt={blogPosts[0].excerpt}
          category={blogPosts[0].category}
          date={blogPosts[0].date}
          readTime={blogPosts[0].readTime}
          image={blogPosts[0].image}
          featured={true}
        />
      </div>

      <!-- Blog Posts Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        {blogPosts.slice(1).map((post) => (
          <BlogCard
            slug={post.slug}
            title={post.title}
            excerpt={post.excerpt}
            category={post.category}
            date={post.date}
            readTime={post.readTime}
            image={post.image}
          />
        ))}
      </div>

      <!-- Newsletter Signup - Redesigned -->
      <div class="relative overflow-hidden bg-gradient-to-br from-primary-600 via-accent-500 to-primary-700 rounded-2xl p-10 text-white text-center shadow-2xl">
        <div class="absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>
        <h2 class="text-2xl md:text-3xl font-bold mb-4 relative z-10">Stay Updated with AI Trends</h2>
        <p class="text-lg text-primary-100 mb-6 max-w-2xl mx-auto relative z-10">
          Get the latest AI chatbot news, reviews, and guides delivered to your inbox weekly.
        </p>
        <form class="max-w-md mx-auto flex gap-3 relative z-10">
          <input 
            type="email" 
            placeholder="Enter your email"
            class="flex-1 px-4 py-3 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-white focus:ring-opacity-50"
          />
          <button 
            type="submit"
            class="px-6 py-3 bg-white text-primary-600 rounded-lg hover:bg-gray-100 transition-colors font-medium"
          >
            Subscribe
          </button>
        </form>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  function filterPosts(category) {
    // Update active button
    document.querySelectorAll('button[onclick*="filterPosts"]').forEach(btn => {
      btn.classList.remove('bg-black', 'text-white');
      btn.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
    });
    
    event.target.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
    event.target.classList.add('bg-black', 'text-white');
    
    // Filter logic would go here in a real implementation
    console.log('Filtering by:', category);
  }
</script>