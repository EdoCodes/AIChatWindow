---
export interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'AIChatWindow - Your gateway to AI chat solutions. Discover free, corporate, and premium AI tools. Compare models side-by-side and find the perfect AI assistant.',
  canonicalURL,
} = Astro.props;
const siteURL = 'https://aichatwindow.com';
const canonical = canonicalURL ?? (siteURL + Astro.url.pathname);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="wkxFBgTwEZhp_gfBVL0jpbPir7ge1pk8TX4ExD9bZTI" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <meta name="keywords" content="AI chat, free AI tools, corporate AI tools, paid AI tools, artificial intelligence, chatbots, AI solutions, AIChatWindow" />
    <meta name="author" content="AIChatWindow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="AIChatWindow" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Preconnect to external services -->
    <link rel="preconnect" href="https://huggingface.co" />
    <link rel="dns-prefetch" href="//huggingface.co" />
    
    <title>{title}</title>
  </head>
  <body class="antialiased bg-white text-gray-900 font-sans">
    <slot />
    
    <!-- Global styles -->
    <style is:global>
      html {
        scroll-behavior: smooth;
        font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
      }

      body {
        font-family: 'Plus Jakarta Sans', 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        letter-spacing: -0.01em;
      }
      
      /* Smooth transitions for all interactive elements */
      a, button {
        transition: all 0.2s ease-in-out;
      }
      
      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 10px;
      }

      ::-webkit-scrollbar-track {
        background: #f1f5f9;
      }

      ::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #3b82f6, #06b6d4);
        border-radius: 5px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(180deg, #2563eb, #0891b2);
      }

      /* Selection colors */
      ::selection {
        background: #3b82f6;
        color: white;
      }
      
      /* Focus states for accessibility */
      button:focus,
      a:focus,
      iframe:focus {
        outline: 2px solid #3b82f6;
        outline-offset: 2px;
      }

      /* Improved button focus */
      button:focus-visible {
        outline: 2px solid #3b82f6;
      }

      /* ─── Global tool-page button normalization ─── */
      /* Ensure primary-600 blue buttons across tool pages are compact */
      a.bg-primary-600,
      a[class*="bg-primary-6"],
      a.bg-blue-600,
      a.bg-blue-700 {
        padding: 7px 14px;
        font-size: 13px;
        font-weight: 600;
        border-radius: 6px;
        line-height: 1.4;
      }

      /* ─── Tool card consistency ─── */
      /* Keep tool page cards clean and flat */
      .tool-card-grid .shadow-lg {
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      }
      .tool-card-grid .hover\:shadow-xl:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.10);
      }
      
      /* Loading animation */
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      
      @keyframes slideUp {
        from { 
          opacity: 0; 
          transform: translateY(20px); 
        }
        to { 
          opacity: 1; 
          transform: translateY(0); 
        }
      }
      
      .animate-fade-in {
        animation: fadeIn 0.5s ease-in-out;
      }
      
      .animate-slide-up {
        animation: slideUp 0.5s ease-out;
      }
    </style>
  </body>
</html>