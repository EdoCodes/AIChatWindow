---
import LoadingSpinner from './LoadingSpinner.astro';

export interface Props {
  serviceId: string;
  serviceName: string;
  displayName: string;
  embedUrl: string;
  description: string;
}

const { serviceId, serviceName, displayName, embedUrl, description } = Astro.props;
---

<div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden transition-all duration-300 hover:shadow-xl group">
  <div class="bg-gradient-to-r from-primary-50 to-secondary-50 px-6 py-4 border-b border-gray-200">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors duration-200">
          {displayName}
        </h3>
        <p class="text-sm text-gray-600 mt-1">{description}</p>
      </div>
      <div class="flex items-center space-x-2">
        <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse-subtle"></div>
        <span class="text-xs text-gray-500">Online</span>
      </div>
    </div>
  </div>

  <div class="relative h-96 bg-gray-50">
    <div id={`loading-${serviceId}`} class="absolute inset-0 z-10 bg-white">
      <LoadingSpinner />
    </div>
    
    <iframe
      id={`chat-${serviceId}`}
      src={embedUrl}
      class="w-full h-full border-0 opacity-0 transition-opacity duration-500"
      allow="microphone; camera"
      referrerpolicy="no-referrer-when-downgrade"
      sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
      onload={`
        document.getElementById('loading-${serviceId}').style.display = 'none';
        this.style.opacity = '1';
        window.analyticsTracker?.createSession('${serviceName}');
      `}
      onerror={`
        document.getElementById('loading-${serviceId}').innerHTML = '<div class="flex items-center justify-center h-64"><div class="text-center"><div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4"><svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><p class="text-sm text-gray-600 mb-2">Unable to load chat</p><button onclick="location.reload()" class="text-xs text-primary-600 hover:text-primary-700">Retry</button></div></div>';
      `}
    ></iframe>
  </div>

  <div class="px-6 py-4 bg-gray-50 border-t border-gray-200">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <button
          class="text-sm text-gray-600 hover:text-primary-600 transition-colors duration-200"
          onclick={`document.getElementById('feedback-modal-${serviceId}').classList.remove('hidden')`}
        >
          <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          Rate
        </button>
        <span class="text-xs text-gray-400">•</span>
        <span class="text-xs text-gray-500">Powered by {serviceName}</span>
      </div>
    </div>
  </div>
</div>

<!-- Feedback Modal -->
<div id={`feedback-modal-${serviceId}`} class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
  <div class="bg-white rounded-lg p-6 max-w-md w-mx-4 animate-slide-up">
    <h3 class="text-lg font-semibold mb-4">Rate {displayName}</h3>
    <div class="mb-4">
      <p class="text-sm text-gray-600 mb-2">How was your experience?</p>
      <div class="flex space-x-1" id={`stars-${serviceId}`}>
        {[1,2,3,4,5].map(rating => (
          <button
            class="w-8 h-8 text-gray-300 hover:text-yellow-400 transition-colors duration-200"
            onclick={`selectRating(${rating}, '${serviceId}')`}
            key={rating}
          >
            <svg class="w-full h-full" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </button>
        ))}
      </div>
    </div>
    <div class="mb-4">
      <textarea
        id={`comment-${serviceId}`}
        placeholder="Optional feedback..."
        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent resize-none"
        rows="3"
      ></textarea>
    </div>
    <div class="flex justify-end space-x-3">
      <button
        onclick={`document.getElementById('feedback-modal-${serviceId}').classList.add('hidden')`}
        class="px-4 py-2 text-gray-600 hover:text-gray-800 transition-colors duration-200"
      >
        Cancel
      </button>
      <button
        onclick={`submitFeedback('${serviceId}', '${serviceName}')`}
        class="px-4 py-2 bg-primary-600 text-white rounded-md hover:bg-primary-700 transition-colors duration-200"
      >
        Submit
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ serviceId, serviceName }}>
let selectedRating = 0;

function selectRating(rating, serviceId) {
  selectedRating = rating;
  const stars = document.getElementById(`stars-${serviceId}`).children;
  for (let i = 0; i < stars.length; i++) {
    stars[i].classList.toggle('text-yellow-400', i < rating);
    stars[i].classList.toggle('text-gray-300', i >= rating);
  }
}

function submitFeedback(serviceId, serviceName) {
  const comment = document.getElementById(`comment-${serviceId}`).value;
  
  if (selectedRating === 0) {
    alert('Please select a rating');
    return;
  }

  // Submit feedback via analytics
  if (window.analyticsTracker) {
    window.analyticsTracker.submitFeedback(serviceName, selectedRating, comment);
  }

  // Hide modal and show thank you
  document.getElementById(`feedback-modal-${serviceId}`).classList.add('hidden');
  
  // Show success message (you could make this a toast notification)
  alert('Thank you for your feedback!');
  
  // Reset form
  selectedRating = 0;
  document.getElementById(`comment-${serviceId}`).value = '';
  const stars = document.getElementById(`stars-${serviceId}`).children;
  for (let i = 0; i < stars.length; i++) {
    stars[i].classList.add('text-gray-300');
    stars[i].classList.remove('text-yellow-400');
  }
}
</script>