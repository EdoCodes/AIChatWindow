---
import LoadingSpinner from './LoadingSpinner.astro';
import FunctionalChatWindow from './FunctionalChatWindow.astro';

export interface Props {
  serviceId: string;
  serviceName: string;
  displayName: string;
  embedUrl: string;
  description: string;
}

const { serviceId, serviceName, displayName, embedUrl, description } = Astro.props;
---

<FunctionalChatWindow 
  title={displayName}
  serviceId={serviceId}
/>