---
export interface Props {
  title?: string;
  proprofsId?: string;
  embedUrl?: string;
}

const { 
  title = "AI Chat Assistant", 
  proprofsId = "default",
  embedUrl = "https://secure.proprofs.com/chat/web/1234567" 
} = Astro.props;
---

<div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden max-w-md w-full relative">
  <!-- Chat Header -->
  <div class="bg-gradient-to-r from-primary-500 to-secondary-500 px-4 py-3 text-white">
    <div class="flex items-center justify-between">
      <h3 class="font-semibold">{title}</h3>
      <div class="flex items-center space-x-2">
        <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
        <span class="text-xs opacity-90">Online</span>
      </div>
    </div>
  </div>

  <!-- ProProfs Chat Embed -->
  <div class="relative h-80 bg-gray-50">
    <div id={`loading-${proprofsId}`} class="absolute inset-0 z-10 bg-white flex items-center justify-center">
      <div class="text-center">
        <div class="w-8 h-8 border-4 border-primary-200 border-t-primary-500 rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-sm text-gray-600">Connecting to chat...</p>
      </div>
    </div>
    
    <iframe
      id={`chat-iframe-${proprofsId}`}
      src={embedUrl}
      class="w-full h-full border-0 opacity-0 transition-opacity duration-500"
      allow="microphone; camera"
      referrerpolicy="no-referrer-when-downgrade"
      sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"
      onload={`
        document.getElementById('loading-${proprofsId}').style.display = 'none';
        this.style.opacity = '1';
      `}
      onerror={`
        document.getElementById('loading-${proprofsId}').innerHTML = '<div class="flex items-center justify-center h-full"><div class="text-center"><div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4"><svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div><p class="text-sm text-gray-600 mb-2">Chat temporarily unavailable</p><button onclick="location.reload()" class="text-xs text-primary-600 hover:text-primary-700 underline">Retry</button></div></div>';
      `}
    ></iframe>
  </div>

  <!-- Chat Info Footer -->
  <div class="px-4 py-3 bg-gray-50 border-t border-gray-200">
    <div class="flex items-center justify-between text-xs text-gray-500">
      <span>Powered by ProProfs Chat</span>
      <div class="flex items-center space-x-1">
        <div class="w-2 h-2 bg-green-400 rounded-full"></div>
        <span>Live Support</span>
      </div>
    </div>
  </div>