---
export interface Props {
  title?: string;
  serviceId?: string;
}

const { 
  title = "AI Chat Assistant", 
  serviceId = "default"
} = Astro.props;
---

<div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden max-w-md w-full relative">
  <!-- Chat Header -->
  <div class="bg-gradient-to-r from-primary-500 to-secondary-500 px-4 py-3 text-white">
    <div class="flex items-center justify-between">
      <h3 class="font-semibold">{title}</h3>
      <div class="flex items-center space-x-2">
        <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
        <span class="text-xs opacity-90">Online</span>
      </div>
    </div>
  </div>

  <!-- Chat Messages Area with Elfsight Integration -->
  <div class="h-80 bg-white relative">
    <!-- Elfsight AI Chatbot | Untitled AI Chatbot -->
    <script src="https://static.elfsight.com/platform/platform.js" async></script>
    <div class="elfsight-app-a5726298-4c2f-41c3-811e-2878a68d5362" data-elfsight-app-lazy style="width: 100%; height: 100%; border: none;"></div>
  </div>

  <!-- Chat Info Footer -->
  <div class="px-4 py-2 bg-gray-50 border-t border-gray-200">
    <div class="flex items-center justify-between text-xs text-gray-500">
      <span>Powered by Elfsight AI</span>
      <div class="flex items-center space-x-1">
        <div class="w-2 h-2 bg-green-400 rounded-full"></div>
        <span>AI Chatbot</span>
      </div>
    </div>
  </div>
</div>