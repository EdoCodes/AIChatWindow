---
import { getActiveServices } from '../lib/ai-services';
import ChatWindow from './ChatWindow.astro';

const services = await getActiveServices();
---

<section id="compare" class="py-16 bg-gradient-to-br from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">
        Compare AI Models Side-by-Side
      </h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Interact with multiple AI chat services simultaneously to discover their unique capabilities, 
        response styles, and find the perfect AI companion for your needs.
      </p>
    </div>

    <!-- Desktop: 3 columns -->
    <div class="hidden lg:grid lg:grid-cols-3 lg:gap-8 mb-8">
      {services.slice(0, 3).map(service => (
        <ChatWindow
          serviceId={service.id}
          serviceName={service.name}
          displayName={service.displayName}
          embedUrl={service.embedUrl}
          description={service.description}
        />
      ))}
    </div>

    <!-- Tablet: 2 columns -->
    <div class="hidden md:grid md:grid-cols-2 lg:hidden gap-6 mb-8">
      {services.slice(0, 2).map(service => (
        <ChatWindow
          serviceId={service.id}
          serviceName={service.name}
          displayName={service.displayName}
          embedUrl={service.embedUrl}
          description={service.description}
        />
      ))}
    </div>

    <!-- Mobile: Tabbed interface -->
    <div class="md:hidden">
      <div class="border-b border-gray-200 mb-6">
        <nav class="flex space-x-8">
          {services.slice(0, 3).map((service, index) => (
            <button
              key={service.id}
              class={`py-2 px-1 border-b-2 font-medium text-sm transition-colors duration-200 ${
                index === 0 
                  ? 'border-primary-500 text-primary-600' 
                  : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
              }`}
              onclick={`switchMobileTab('${service.id}', this)`}
            >
              {service.displayName}
            </button>
          ))}
        </nav>
      </div>

      {services.slice(0, 3).map((service, index) => (
        <div
          key={service.id}
          id={`mobile-tab-${service.id}`}
          class={index === 0 ? 'block' : 'hidden'}
        >
          <ChatWindow
            serviceId={service.id}
            serviceName={service.name}
            displayName={service.displayName}
            embedUrl={service.embedUrl}
            description={service.description}
          />
        </div>
      ))}
    </div>

    <!-- Usage Stats -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="text-center p-6 bg-white rounded-lg shadow-sm border border-gray-200">
        <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Real-time Comparison</h3>
        <p class="text-gray-600 text-sm">Compare responses from multiple AI models simultaneously</p>
      </div>

      <div class="text-center p-6 bg-white rounded-lg shadow-sm border border-gray-200">
        <div class="w-12 h-12 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">No Registration</h3>
        <p class="text-gray-600 text-sm">Start chatting immediately without creating an account</p>
      </div>

      <div class="text-center p-6 bg-white rounded-lg shadow-sm border border-gray-200">
        <div class="w-12 h-12 bg-accent-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Free to Use</h3>
        <p class="text-gray-600 text-sm">All AI models are completely free with no usage limits</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
function switchMobileTab(serviceId, buttonElement) {
  // Hide all tabs
  document.querySelectorAll('[id^="mobile-tab-"]').forEach(tab => {
    tab.classList.add('hidden');
  });
  
  // Show selected tab
  document.getElementById(`mobile-tab-${serviceId}`).classList.remove('hidden');
  
  // Update button states
  document.querySelectorAll('button[onclick*="switchMobileTab"]').forEach(btn => {
    btn.classList.remove('border-primary-500', 'text-primary-600');
    btn.classList.add('border-transparent', 'text-gray-500');
  });
  
  // Activate selected button
  buttonElement.classList.remove('border-transparent', 'text-gray-500');
  buttonElement.classList.add('border-primary-500', 'text-primary-600');
}
</script>