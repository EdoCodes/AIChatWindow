---
---

<footer class="bg-gray-900 border-t border-green-400/30 relative overflow-hidden">
  <!-- PCB Background Pattern -->
  <div class="absolute inset-0 opacity-15">
    <svg class="w-full h-full" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="footer-pcb-pattern" x="0" y="0" width="200" height="200" patternUnits="userSpaceOnUse">
          <!-- Main circuit traces -->
          <line x1="0" y1="50" x2="200" y2="50" stroke="#00ff41" stroke-width="1" opacity="0.6"/>
          <line x1="0" y1="100" x2="200" y2="100" stroke="#00ff41" stroke-width="0.8" opacity="0.5"/>
          <line x1="0" y1="150" x2="200" y2="150" stroke="#00ff41" stroke-width="1" opacity="0.6"/>
          
          <line x1="50" y1="0" x2="50" y2="200" stroke="#00ff41" stroke-width="0.8" opacity="0.5"/>
          <line x1="100" y1="0" x2="100" y2="200" stroke="#00ff41" stroke-width="1" opacity="0.6"/>
          <line x1="150" y1="0" x2="150" y2="200" stroke="#00ff41" stroke-width="0.8" opacity="0.5"/>
          
          <!-- Circuit nodes and components -->
          <circle cx="50" cy="50" r="3" fill="#00ff41" opacity="0.8"/>
          <circle cx="100" cy="100" r="3" fill="#00ff41" opacity="0.8"/>
          <circle cx="150" cy="150" r="3" fill="#00ff41" opacity="0.8"/>
          <circle cx="150" cy="50" r="2" fill="#00ff41" opacity="0.6"/>
          <circle cx="50" cy="150" r="2" fill="#00ff41" opacity="0.6"/>
          
          <!-- Microchip representations -->
          <rect x="90" y="40" width="20" height="20" fill="none" stroke="#00ff41" stroke-width="0.8" opacity="0.7"/>
          <rect x="40" y="90" width="20" height="20" fill="none" stroke="#00ff41" stroke-width="0.8" opacity="0.7"/>
          <rect x="140" y="140" width="20" height="20" fill="none" stroke="#00ff41" stroke-width="0.8" opacity="0.7"/>
          
          <!-- Small connection lines -->
          <line x1="95" y1="40" x2="95" y2="35" stroke="#00ff41" stroke-width="0.5" opacity="0.5"/>
          <line x1="105" y1="40" x2="105" y2="35" stroke="#00ff41" stroke-width="0.5" opacity="0.5"/>
          <line x1="95" y1="60" x2="95" y2="65" stroke="#00ff41" stroke-width="0.5" opacity="0.5"/>
          <line x1="105" y1="60" x2="105" y2="65" stroke="#00ff41" stroke-width="0.5" opacity="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#footer-pcb-pattern)"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand Section -->
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center space-x-3 mb-6">
          <div class="w-10 h-10 bg-green-400 rounded-lg flex items-center justify-center relative">
            <svg class="w-6 h-6 text-gray-900" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z" />
              <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z" />
            </svg>
            <!-- Circuit overlay on logo -->
            <div class="absolute inset-0 opacity-30">
              <svg class="w-full h-full" viewBox="0 0 40 40">
                <line x1="8" y1="12" x2="32" y2="12" stroke="#000" stroke-width="0.5"/>
                <line x1="8" y1="28" x2="32" y2="28" stroke="#000" stroke-width="0.5"/>
                <circle cx="20" cy="20" r="1" fill="#000"/>
              </svg>
            </div>
          </div>
          <span class="text-2xl font-bold text-green-400 font-mono tracking-wider">AIChatWindow</span>
        </div>
        <p class="text-green-200 mb-6 max-w-md leading-relaxed font-mono text-sm">
          Your comprehensive platform for discovering, comparing, and integrating AI chat solutions. 
          From free tools to enterprise platforms, find the perfect AI assistant for every need.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="text-green-300 hover:text-green-400 transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </a>
          <a href="#" class="text-green-300 hover:text-green-400 transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="text-green-300 hover:text-green-400 transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.097.118.112.221.083.343-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- AI Tools -->
      <div>
        <h3 class="text-sm font-bold text-green-400 uppercase tracking-wider mb-4 font-mono">AI TOOLS</h3>
        <ul class="space-y-3">
          <li><a href="/free-ai-tools" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">Free AI Tools</a></li>
          <li><a href="/corporate-ai-tools" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">Corporate AI Tools</a></li>
          <li><a href="/paid-ai-tools" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">Paid AI Tools</a></li>
          <li><a href="/chat" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">Try Free Chat</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-bold text-green-400 uppercase tracking-wider mb-4 font-mono">COMPANY</h3>
        <ul class="space-y-3">
          <li><a href="/about" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">About</a></li>
          <li><a href="/blog" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">Blog</a></li>
          <li><a href="/careers" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">Careers</a></li>
          <li><a href="/contact" class="text-green-200 hover:text-green-400 transition-colors duration-200 font-mono text-sm">Contact</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-green-400/30 mt-12 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-green-300 text-sm font-mono">
          &copy; 2025 AIChatWindow. All rights reserved.
        </p>
        <div class="flex space-x-6 mt-4 md:mt-0">
          <a href="/privacy" class="text-green-300 hover:text-green-400 text-sm transition-colors duration-200 font-mono">Privacy Policy</a>
          <a href="/terms" class="text-green-300 hover:text-green-400 text-sm transition-colors duration-200 font-mono">Terms of Service</a>
          <a href="/cookies" class="text-green-300 hover:text-green-400 text-sm transition-colors duration-200 font-mono">Cookie Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>