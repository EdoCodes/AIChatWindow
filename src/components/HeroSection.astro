---
import CommunityShowcase from './CommunityShowcase.astro';
---

<section class="pt-20 pb-8 bg-black border-b border-gray-800 relative overflow-hidden">
  <!-- Matrix Background -->
  <div class="absolute inset-0 opacity-20">
    <canvas id="matrix-canvas" class="w-full h-full"></canvas>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex justify-center">
      <div class="w-full max-w-2xl">
        <!-- Chat Window -->
        <div class="bg-black rounded-xl shadow-2xl border border-green-500/30 overflow-hidden backdrop-blur-sm">
          <!-- Chat Header -->
          <div class="bg-gradient-to-r from-green-900/50 to-green-800/50 px-4 py-3 border-b border-green-500/30">
            <div class="flex items-center justify-between">
              <h3 class="font-mono font-bold text-green-400 text-lg tracking-wider">CHAT WINDOW</h3>
              <div class="flex items-center space-x-2">
                <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                <span class="text-xs text-green-300 font-mono">ONLINE</span>
              </div>
            </div>
          </div>

          <!-- Chat Messages Container -->
          <div class="h-80 bg-black/90 relative">
            <!-- Chat Messages -->
            <div id="hero-chat-messages" class="h-full p-4 overflow-y-auto">
              <div class="space-y-4">
                <!-- Welcome Message -->
                <div class="flex items-start space-x-2">
                  <div class="w-8 h-8 bg-green-400 rounded-full flex items-center justify-center text-black text-sm font-bold">
                    AI
                  </div>
                  <div class="bg-green-900/50 border border-green-500/30 rounded-lg p-3 max-w-xs">
                    <p class="text-sm text-green-300 font-mono">SYSTEM INITIALIZED. AI ASSISTANT ONLINE.</p>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Chat Input -->
            <div class="absolute bottom-0 left-0 right-0 border-t border-green-500/30 p-4 bg-black/90">
              <div class="flex space-x-2">
                <input 
                  type="text" 
                  id="hero-chat-input"
                  placeholder="ENTER COMMAND..." 
                  class="flex-1 px-3 py-2 bg-black border border-green-500/30 rounded text-green-400 placeholder-green-600 focus:outline-none focus:border-green-400 font-mono text-sm"
                />
                <button 
                  id="hero-chat-send"
                  class="px-4 py-2 bg-green-400 text-black rounded hover:bg-green-300 focus:outline-none transition-colors font-mono font-bold text-sm"
                >
                  SEND
                </button>
              </div>
            </div>
          </div>

          <!-- Footer -->
          <div class="border-t border-green-500/30 p-4 bg-black/90">
            <div class="text-center text-green-400 font-mono text-sm">
              AI CHATBOT SYSTEM ACTIVE
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<CommunityShowcase />

<script>
  // Matrix Rain Effect
  class MatrixRain {
    constructor() {
      this.canvas = document.getElementById('matrix-canvas');
      if (!this.canvas) return;
      
      this.ctx = this.canvas.getContext('2d');
      this.resizeCanvas();
      this.drops = [];
      this.chars = '01';
      this.fontSize = 14;
      this.columns = Math.floor(this.canvas.width / this.fontSize);
      
      // Initialize drops
      for (let i = 0; i < this.columns; i++) {
        this.drops[i] = Math.random() * this.canvas.height;
      }
      
      this.animate();
      window.addEventListener('resize', () => this.resizeCanvas());
    }
    
    resizeCanvas() {
      this.canvas.width = this.canvas.offsetWidth;
      this.canvas.height = this.canvas.offsetHeight;
      this.columns = Math.floor(this.canvas.width / this.fontSize);
    }
    
    animate() {
      // Semi-transparent black background for trail effect
      this.ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
      
      // Green text
      this.ctx.fillStyle = '#00ff41';
      this.ctx.font = `${this.fontSize}px monospace`;
      
      for (let i = 0; i < this.drops.length; i++) {
        const char = this.chars[Math.floor(Math.random() * this.chars.length)];
        const x = i * this.fontSize;
        const y = this.drops[i] * this.fontSize;
        
        this.ctx.fillText(char, x, y);
        
        // Reset drop to top randomly
        if (y > this.canvas.height && Math.random() > 0.975) {
          this.drops[i] = 0;
        }
        
        this.drops[i]++;
      }
      
      requestAnimationFrame(() => this.animate());
    }
  }

  // Initialize Matrix Rain when DOM is loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      new MatrixRain();
      initHeroChat();
    });
  } else {
    new MatrixRain();
    initHeroChat();
  }

  // Hero Chat Functionality
  function initHeroChat() {
    const messagesContainer = document.getElementById('hero-chat-messages');
    const chatInput = document.getElementById('hero-chat-input');
    const sendButton = document.getElementById('hero-chat-send');

    if (!messagesContainer || !chatInput || !sendButton) return;

    const responses = [
      "ANALYZING REQUEST... AI CHATBOTS ARE THE FUTURE OF DIGITAL COMMUNICATION.",
      "PROCESSING... RECOMMEND EXPLORING FREE AI TOOLS: GOOGLE BARD, CHARACTER.AI, PERPLEXITY.",
      "SYSTEM RESPONSE: AI TECHNOLOGY ADVANCING RAPIDLY. CHATGPT, CLAUDE, BARD LEADING INNOVATION.",
      "DATA RETRIEVED: OVER 50 AI CHATBOTS AVAILABLE. EACH WITH UNIQUE CAPABILITIES.",
      "QUERY PROCESSED: AI ASSISTANTS REVOLUTIONIZING CUSTOMER SERVICE AND PRODUCTIVITY.",
      "INFORMATION COMPILED: FREE AI TOOLS DEMOCRATIZING ACCESS TO ARTIFICIAL INTELLIGENCE.",
      "ANALYSIS COMPLETE: ENTERPRISE AI SOLUTIONS TRANSFORMING BUSINESS OPERATIONS.",
      "SYSTEM UPDATE: AI CHATBOTS BECOMING ESSENTIAL FOR MODERN DIGITAL EXPERIENCES."
    ];
    
    function addMessage(content, isUser = false) {
      const messageDiv = document.createElement('div');
      messageDiv.className = 'flex items-start space-x-2';
      
      if (isUser) {
        messageDiv.className += ' justify-end';
        messageDiv.innerHTML = `
          <div class="bg-green-400/20 border border-green-400/30 rounded-lg p-3 max-w-xs">
            <p class="text-sm text-green-300 font-mono">${content.toUpperCase()}</p>
          </div>
          <div class="w-8 h-8 bg-green-400/20 border border-green-400/30 rounded-full flex items-center justify-center text-green-400 text-sm font-bold">
            U
          </div>
        `;
      } else {
        messageDiv.innerHTML = `
          <div class="w-8 h-8 bg-green-400 rounded-full flex items-center justify-center text-black text-sm font-bold">
            AI
          </div>
          <div class="bg-green-900/50 border border-green-500/30 rounded-lg p-3 max-w-xs">
            <p class="text-sm text-green-300 font-mono">${content}</p>
          </div>
        `;
      }
      
      messagesContainer.appendChild(messageDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }
    
    function showTypingIndicator() {
      const typingDiv = document.createElement('div');
      typingDiv.className = 'flex items-start space-x-2 typing-indicator';
      typingDiv.innerHTML = `
        <div class="w-8 h-8 bg-green-400 rounded-full flex items-center justify-center text-black text-sm font-bold">
          AI
        </div>
        <div class="bg-green-900/50 border border-green-500/30 rounded-lg p-3">
          <div class="flex space-x-1">
            <div class="w-2 h-2 bg-green-400 rounded-full animate-bounce"></div>
            <div class="w-2 h-2 bg-green-400 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
            <div class="w-2 h-2 bg-green-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
          </div>
        </div>
      `;
      messagesContainer.appendChild(typingDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
      return typingDiv;
    }
    
    function handleSend() {
      const message = chatInput.value.trim();
      if (!message) return;
      
      // Add user message
      addMessage(message, true);
      chatInput.value = '';
      
      // Show typing indicator
      const typingIndicator = showTypingIndicator();
      
      // Generate and show AI response after delay
      setTimeout(() => {
        typingIndicator.remove();
        const response = responses[Math.floor(Math.random() * responses.length)];
        addMessage(response, false);
      }, 1000 + Math.random() * 1500);
    }
    
    // Event listeners
    sendButton.addEventListener('click', handleSend);
    chatInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        handleSend();
      }
    });
  }
</script>