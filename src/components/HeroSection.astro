---
import CommunityShowcase from './CommunityShowcase.astro';
---

<section class="pt-20 pb-8 bg-black border-b border-gray-800 relative overflow-hidden">
  <!-- Matrix Background -->
  <div class="absolute inset-0 opacity-20">
    <canvas id="matrix-canvas" class="w-full h-full"></canvas>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex justify-center">
      <div class="w-full max-w-2xl">
        <!-- Chat Window -->
        <div class="bg-black rounded-xl shadow-2xl border border-green-500/30 overflow-hidden backdrop-blur-sm">
          <!-- Chat Header -->
          <div class="bg-gradient-to-r from-green-900/50 to-green-800/50 px-4 py-3 border-b border-green-500/30">
            <div class="flex items-center justify-between">
              <h3 class="font-mono font-bold text-green-400 text-lg tracking-wider">CHAT WINDOW</h3>
              <div class="flex items-center space-x-2">
                <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                <span class="text-xs text-green-300 font-mono">ONLINE</span>
              </div>
            </div>
          </div>

          <!-- Chat Messages Container -->
          <div id="chat-messages-hero" class="h-80 overflow-y-auto p-4 space-y-3 bg-black/90">
            <div class="flex items-start space-x-2">
              <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 border border-green-400">
                <svg class="w-4 h-4 text-black" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              </div>
              <div class="bg-green-900/30 rounded-lg px-3 py-2 border border-green-500/30 max-w-xs">
                <p class="text-sm text-green-300 font-mono">SYSTEM INITIALIZED. HOW CAN I ASSIST YOU TODAY?</p>
              </div>
            </div>
          </div>

          <!-- Chat Input -->
          <div class="border-t border-green-500/30 p-4 bg-black/90">
            <form id="chat-form-hero" class="flex space-x-2">
              <input
                type="text"
                id="chat-input-hero"
                placeholder="Enter your message..."
                class="flex-1 px-3 py-2 bg-black border border-green-500/50 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-green-400 text-green-300 font-mono placeholder-green-600"
                autocomplete="off"
              />
              <button
                type="submit"
                id="send-button-hero"
                class="px-4 py-2 bg-green-500 text-black rounded-lg hover:bg-green-400 focus:outline-none focus:ring-2 focus:ring-green-400 focus:ring-offset-2 focus:ring-offset-black transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed font-mono font-bold"
              >
                SEND
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<CommunityShowcase />

<section class="pt-16 pb-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Main Heading -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-gray-900 mb-8 leading-tight tracking-tight">
        Your Gateway to
        <span class="block text-black">AI Chat Solutions</span>
      </h1>
      
      <p class="text-xl text-gray-600 mb-12 leading-relaxed max-w-3xl mx-auto">
        Discover, compare, and integrate the perfect AI chat tools for your needs. 
        From free solutions to enterprise-grade platforms, find everything in one place.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
        <a href="/free-ai-tools" class="inline-flex items-center px-8 py-4 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 transition-all duration-200">
          <span>Explore Free Tools</span>
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        
        <a href="/chat" class="inline-flex items-center px-8 py-4 bg-white text-gray-700 font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-all duration-200">
          <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <span>Try Free Chat</span>
        </a>
      </div>

      <!-- Feature Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-20">
        <!-- Free Tools -->
        <div class="text-center p-8 bg-gray-50 rounded-2xl border border-gray-200">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Free AI Tools</h3>
          <p class="text-gray-600 leading-relaxed">Access powerful AI chat models like DialoGPT, BlenderBot, and browser-based AI at no cost.</p>
        </div>

        <!-- Corporate Tools -->
        <div class="text-center p-8 bg-gray-50 rounded-2xl border border-gray-200">
          <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Corporate Solutions</h3>
          <p class="text-gray-600 leading-relaxed">Enterprise-grade AI tools for business automation, customer service, and team productivity.</p>
        </div>

        <!-- Premium Tools -->
        <div class="text-center p-8 bg-gray-50 rounded-2xl border border-gray-200">
          <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Premium Features</h3>
          <p class="text-gray-600 leading-relaxed">Advanced AI capabilities with premium models, enhanced features, and priority support.</p>
        </div>
      </div>

      <!-- Trust Indicators -->
      <div class="mt-20 pt-12 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-8">Trusted by developers and businesses worldwide</p>
        <div class="flex justify-center items-center space-x-12 opacity-60">
          <div class="text-center">
            <div class="text-2xl font-bold text-gray-900">10K+</div>
            <div class="text-xs text-gray-500">Active Users</div>
          </div>
          <div class="w-px h-8 bg-gray-300"></div>
          <div class="text-center">
            <div class="text-2xl font-bold text-gray-900">50+</div>
            <div class="text-xs text-gray-500">AI Models</div>
          </div>
          <div class="w-px h-8 bg-gray-300"></div>
          <div class="text-center">
            <div class="text-2xl font-bold text-gray-900">99.9%</div>
            <div class="text-xs text-gray-500">Uptime</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Matrix Rain Effect
  class MatrixRain {
    constructor() {
      this.canvas = document.getElementById('matrix-canvas');
      if (!this.canvas) return;
      
      this.ctx = this.canvas.getContext('2d');
      this.resizeCanvas();
      this.drops = [];
      this.chars = '01';
      this.fontSize = 14;
      this.columns = Math.floor(this.canvas.width / this.fontSize);
      
      // Initialize drops
      for (let i = 0; i < this.columns; i++) {
        this.drops[i] = Math.random() * this.canvas.height;
      }
      
      this.animate();
      window.addEventListener('resize', () => this.resizeCanvas());
    }
    
    resizeCanvas() {
      this.canvas.width = this.canvas.offsetWidth;
      this.canvas.height = this.canvas.offsetHeight;
      this.columns = Math.floor(this.canvas.width / this.fontSize);
    }
    
    animate() {
      // Semi-transparent black background for trail effect
      this.ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
      
      // Green text
      this.ctx.fillStyle = '#00ff41';
      this.ctx.font = `${this.fontSize}px monospace`;
      
      for (let i = 0; i < this.drops.length; i++) {
        const char = this.chars[Math.floor(Math.random() * this.chars.length)];
        const x = i * this.fontSize;
        const y = this.drops[i] * this.fontSize;
        
        this.ctx.fillText(char, x, y);
        
        // Reset drop to top randomly
        if (y > this.canvas.height && Math.random() > 0.975) {
          this.drops[i] = 0;
        }
        
        this.drops[i]++;
      }
      
      requestAnimationFrame(() => this.animate());
    }
  }

  // Chat Interface
  class HeroChatInterface {
    constructor() {
      this.chatBot = this.createChatBot();
      this.messagesContainer = document.getElementById('chat-messages-hero');
      this.chatForm = document.getElementById('chat-form-hero');
      this.chatInput = document.getElementById('chat-input-hero');
      this.sendButton = document.getElementById('send-button-hero');
      
      if (this.chatForm && this.chatInput && this.sendButton && this.messagesContainer) {
        this.init();
      }
    }

    init() {
      this.chatForm.addEventListener('submit', (e) => this.handleSubmit(e));
      this.chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          this.handleSubmit(e);
        }
      });
    }

    createChatBot() {
      return {
        responses: {
          greetings: [
            "SYSTEM INITIALIZED. HOW CAN I ASSIST YOU TODAY?",
            "GREETINGS, USER. AI ASSISTANT ONLINE AND READY.",
            "HELLO. WHAT INFORMATION DO YOU REQUIRE?",
            "WELCOME TO THE AI INTERFACE. HOW MAY I HELP?"
          ],
          questions: [
            "PROCESSING QUERY... BASED ON AVAILABLE DATA, I RECOMMEND EXPLORING OUR AI TOOLS SECTION.",
            "ANALYZING REQUEST... OUR PLATFORM OFFERS COMPREHENSIVE AI COMPARISONS.",
            "QUERY RECEIVED. CHECK OUR BLOG FOR DETAILED AI IMPLEMENTATION GUIDES.",
            "INFORMATION REQUEST ACKNOWLEDGED. WHAT SPECIFIC AI CAPABILITIES INTEREST YOU?"
          ],
          aiTopics: [
            "AI SYSTEMS ARE RAPIDLY EVOLVING. OUR DATABASE CONTAINS 50+ AI TOOL COMPARISONS.",
            "ARTIFICIAL INTELLIGENCE QUERY DETECTED. RECOMMEND: CHATGPT, CLAUDE, BARD ANALYSIS.",
            "AI TECHNOLOGY STATUS: ADVANCING. MULTIPLE FREE OPTIONS AVAILABLE FOR EVALUATION.",
            "MACHINE LEARNING SYSTEMS ONLINE. WOULD YOU LIKE SPECIFIC TOOL RECOMMENDATIONS?"
          ],
          defaults: [
            "INPUT RECEIVED. PLEASE SPECIFY YOUR AI REQUIREMENTS FOR OPTIMAL ASSISTANCE.",
            "PROCESSING... WHAT TYPE OF AI SOLUTION ARE YOU SEEKING?",
            "DATA ANALYZED. HOW CAN I HELP YOU NAVIGATE AI TOOLS?",
            "SYSTEM READY. WHAT AI-RELATED INFORMATION DO YOU NEED?",
            "QUERY UNDERSTOOD. OUR PLATFORM SPECIALIZES IN AI TOOL COMPARISONS."
          ]
        },
        
        generateResponse(message) {
          const lowerMessage = message.toLowerCase().trim();
          
          if (this.matchesPatterns(lowerMessage, ['hello', 'hi', 'hey', 'greetings'])) {
            return this.getRandomResponse('greetings');
          }
          
          if (lowerMessage.includes('?') || this.matchesPatterns(lowerMessage, ['what', 'how', 'why', 'when', 'where'])) {
            return this.getRandomResponse('questions');
          }
          
          if (this.matchesPatterns(lowerMessage, ['ai', 'chatbot', 'chat', 'artificial', 'machine learning', 'gpt', 'claude', 'bard'])) {
            return this.getRandomResponse('aiTopics');
          }
          
          return this.getRandomResponse('defaults');
        },
        
        matchesPatterns(message, patterns) {
          return patterns.some(pattern => message.includes(pattern));
        },
        
        getRandomResponse(category) {
          const responses = this.responses[category];
          return responses[Math.floor(Math.random() * responses.length)];
        }
      };
    }

    async handleSubmit(e) {
      e.preventDefault();
      
      const message = this.chatInput.value.trim();
      if (!message) return;

      // Add user message to chat
      this.addMessage(message, 'user');
      this.chatInput.value = '';
      this.setLoading(true);

      // Generate AI response with realistic delay
      setTimeout(() => {
        try {
          const response = this.chatBot.generateResponse(message);
          this.addMessage(response, 'assistant');
        } catch (error) {
          console.error('Chat error:', error);
          this.addMessage("SYSTEM ERROR. REBOOTING... PLEASE TRY AGAIN.", 'assistant');
        } finally {
          this.setLoading(false);
        }
      }, 1000 + Math.random() * 1500);
    }

    addMessage(content, role) {
      const messageDiv = document.createElement('div');
      messageDiv.className = 'flex items-start space-x-2';
      
      if (role === 'user') {
        messageDiv.className += ' justify-end';
        messageDiv.innerHTML = `
          <div class="bg-green-500/20 border border-green-500/50 text-green-300 rounded-lg px-3 py-2 max-w-xs">
            <p class="text-sm font-mono">${this.escapeHtml(content.toUpperCase())}</p>
          </div>
          <div class="w-8 h-8 bg-green-500/30 border border-green-400 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
        `;
      } else {
        messageDiv.innerHTML = `
          <div class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 border border-green-400">
            <svg class="w-4 h-4 text-black" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <div class="bg-green-900/30 rounded-lg px-3 py-2 border border-green-500/30 max-w-xs">
            <p class="text-sm text-green-300 font-mono">${this.escapeHtml(content.toUpperCase())}</p>
          </div>
        `;
      }

      this.messagesContainer.appendChild(messageDiv);
      this.scrollToBottom();
    }

    setLoading(loading) {
      if (loading) {
        this.sendButton.disabled = true;
        this.chatInput.disabled = true;
        this.sendButton.textContent = 'PROCESSING...';
      } else {
        this.sendButton.disabled = false;
        this.chatInput.disabled = false;
        this.sendButton.textContent = 'SEND';
        this.chatInput.focus();
      }
    }

    scrollToBottom() {
      this.messagesContainer.scrollTop = this.messagesContainer.scrollHeight;
    }

    escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  }

  // Initialize everything when DOM is loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      new MatrixRain();
      new HeroChatInterface();
    });
  } else {
    new MatrixRain();
    new HeroChatInterface();
  }
</script>