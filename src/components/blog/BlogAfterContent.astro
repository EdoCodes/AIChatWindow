---
interface RelatedArticle {
  href: string;
  title: string;
  description: string;
  image: string;
}

interface Props {
  relatedArticles?: RelatedArticle[];
  newsletterHeading?: string;
  newsletterSubtitle?: string;
}

const {
  relatedArticles = [],
  newsletterHeading = 'Stay Updated on AI',
  newsletterSubtitle = 'Get weekly AI chatbot comparisons, guides, and tool recommendations delivered to your inbox.',
} = Astro.props;
---

<!-- Author Bio -->
<section class="author-bio-section">
  <div class="author-bio-card">
    <div class="author-photo-wrapper">
      <div class="author-avatar">AI</div>
    </div>
    <div class="author-info">
      <div class="author-label">Written by</div>
      <h3 class="author-name">AIChatWindow Expert Team</h3>
      <p class="author-bio-text">
        Our team evaluates AI chatbots, tools, and platforms so you can make confident decisions.
        We test every product hands-on before writing about it.
      </p>
      <div class="author-credentials">
        <span>100+ tools tested</span>
        <span>Updated weekly</span>
        <span>Since 2024</span>
      </div>
    </div>
  </div>
</section>

<!-- Related Articles -->
{relatedArticles.length > 0 && (
  <section class="related-section">
    <h3 class="related-heading">Related Articles</h3>
    <div class="related-grid">
      {relatedArticles.map((article) => (
        <a href={article.href} class="related-card">
          <img src={article.image} alt={article.title} class="related-image" loading="lazy" />
          <div class="related-body">
            <h4 class="related-title">{article.title}</h4>
            <p class="related-desc">{article.description}</p>
            <span class="related-cta">Read article →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<!-- Newsletter Signup -->
<section class="newsletter-section">
  <div class="newsletter-inner">
    <div class="newsletter-text">
      <h3 class="newsletter-heading">{newsletterHeading}</h3>
      <p class="newsletter-subtitle">{newsletterSubtitle}</p>
    </div>
    <form class="newsletter-form">
      <input type="email" placeholder="Enter your email" class="newsletter-input" />
      <button type="submit" class="newsletter-btn">Subscribe Free</button>
    </form>
  </div>
</section>

<style>
  /* ─── Author Bio ─── */
  .author-bio-section {
    margin-top: 64px;
    padding-top: 40px;
    border-top: 2px solid #e5e7eb;
  }
  .author-bio-card {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    background: #f9fafb;
    padding: 28px;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }
  .author-photo-wrapper { flex-shrink: 0; }
  .author-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 20px;
    font-family: 'Inter', sans-serif;
  }
  .author-info { flex: 1; min-width: 0; }
  .author-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    margin-bottom: 4px;
    font-family: 'Inter', sans-serif;
  }
  .author-name {
    font-size: 18px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 10px 0;
    font-family: 'Inter', sans-serif;
  }
  .author-bio-text {
    font-size: 14px;
    line-height: 1.65;
    color: #4b5563;
    margin: 0 0 12px 0;
    font-family: 'Inter', sans-serif;
  }
  .author-credentials {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .author-credentials span {
    font-size: 12px;
    font-weight: 600;
    color: #6b7280;
    background: #e5e7eb;
    padding: 3px 10px;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
  }

  /* ─── Related Articles ─── */
  .related-section { margin-top: 64px; }
  .related-heading {
    font-size: 22px;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 24px 0;
    padding-bottom: 12px;
    border-bottom: 2px solid #e5e7eb;
    font-family: 'Inter', sans-serif;
    letter-spacing: -0.02em;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .related-card {
    display: block;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
    background: #ffffff;
  }
  .related-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.09);
    transform: translateY(-2px);
  }
  .related-image {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }
  .related-body { padding: 16px; }
  .related-title {
    font-size: 15px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 6px 0;
    line-height: 1.4;
    font-family: 'Inter', sans-serif;
  }
  .related-card:hover .related-title { color: #2563eb; }
  .related-desc {
    font-size: 13px;
    color: #6b7280;
    margin: 0 0 12px 0;
    line-height: 1.5;
    font-family: 'Inter', sans-serif;
  }
  .related-cta {
    font-size: 13px;
    font-weight: 600;
    color: #2563eb;
    font-family: 'Inter', sans-serif;
  }

  /* ─── Newsletter ─── */
  .newsletter-section {
    margin-top: 64px;
    border-radius: 14px;
    border: 1px solid #e5e7eb;
    overflow: hidden;
  }
  .newsletter-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 32px;
    padding: 32px 36px;
    background: #f8fafc;
  }
  @media (max-width: 640px) {
    .newsletter-inner {
      grid-template-columns: 1fr;
      padding: 24px 20px;
      gap: 20px;
    }
  }
  .newsletter-text {}
  .newsletter-heading {
    font-size: 17px;
    font-weight: 800;
    margin: 0 0 6px 0;
    color: #0f172a;
    font-family: 'Inter', sans-serif;
    letter-spacing: -0.02em;
  }
  .newsletter-subtitle {
    font-size: 13px;
    color: #6b7280;
    margin: 0;
    line-height: 1.55;
    font-family: 'Inter', sans-serif;
  }
  .newsletter-form {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .newsletter-form { width: 100%; }
  }
  .newsletter-input {
    padding: 9px 14px;
    border-radius: 8px;
    border: 1px solid #d1d5db;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    color: #111827;
    outline: none;
    background: #fff;
    width: 200px;
    transition: border-color 0.2s;
  }
  .newsletter-input:focus { border-color: #2563eb; }
  @media (max-width: 640px) { .newsletter-input { flex: 1; width: auto; } }
  .newsletter-btn {
    padding: 9px 16px;
    background: #1d4ed8;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .newsletter-btn:hover { background: #1e40af; }
  .newsletter-note {
    display: none;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .author-bio-card { flex-direction: column; }
    .related-grid { grid-template-columns: 1fr; }
    .newsletter-form { flex-direction: column; }
    .newsletter-section { padding: 28px 20px; }
  }
</style>
