---
import Layout from '../../layouts/Layout.astro';
import Header from '../Header.astro';
import Footer from '../Footer.astro';

interface FaqItem {
  question: string;
  answer: string;
}

interface TocItem {
  id: string;
  label: string;
}

interface Props {
  title: string;
  displayTitle?: string;
  description?: string;
  breadcrumbItems: { label: string; href?: string }[];
  category?: string;
  date?: string;
  readTime?: string;
  subtitle?: string;
  heroImage?: string;
  heroImageAlt?: string;
  tocItems?: TocItem[];
  keyTakeaways?: string[];
  faqItems?: FaqItem[];
  author?: string;
  datePublished?: string;
  dateModified?: string;
}

const {
  title,
  displayTitle,
  description,
  breadcrumbItems,
  category,
  date,
  readTime,
  subtitle,
  heroImage,
  heroImageAlt = '',
  tocItems = [],
  keyTakeaways = [],
  faqItems = [],
  author = 'AIChatWindow Expert Team',
  datePublished,
  dateModified,
} = Astro.props;
const heading = displayTitle ?? title;

const siteURL = 'https://aichatwindow.com';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: heading,
  description: description ?? subtitle ?? '',
  author: { '@type': 'Organization', name: author },
  publisher: { '@type': 'Organization', name: 'AIChatWindow', url: siteURL },
  ...(heroImage ? { image: heroImage } : {}),
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
  mainEntityOfPage: { '@type': 'WebPage', '@id': siteURL },
};

const faqSchema = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null;

// Split FAQ into PAA (first 5) and extended FAQ (remaining)
const paaItems = faqItems.slice(0, 5);
const extendedFaqItems = faqItems.slice(5);
---

<Layout title={title} description={description ?? subtitle ?? ''}>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <article class="blog-post">
    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav">
      <div class="container">
        {breadcrumbItems.map((item, i) => (
          <>
            {i > 0 && <span>/</span>}
            {item.href
              ? <a href={item.href}>{item.label}</a>
              : <span class="breadcrumb-current">{item.label}</span>
            }
          </>
        ))}
      </div>
    </nav>

    <!-- Hero Image -->
    {heroImage && (
      <div class="hero-section">
        <img src={heroImage} alt={heroImageAlt || heading} class="hero-image" loading="eager" />
      </div>
    )}

    <!-- Article Header -->
    <header class="article-header">
      <div class="container">
        {category && <span class="category-tag">{category}</span>}
        <h1 class="article-title">{heading}</h1>
        {subtitle && <p class="article-subtitle">{subtitle}</p>}
        <div class="article-meta">
          {date && <time datetime={datePublished}>{date}</time>}
          {date && readTime && <span class="dot">•</span>}
          {readTime && <span>{readTime}</span>}
          {date && <span class="dot">•</span>}
          <span>By {author}</span>
        </div>
      </div>
    </header>

    <!-- Article Body -->
    <div class="article-content">
      <div class="container">

        <!-- What You'll Learn -->
        {keyTakeaways.length > 0 && (
          <div class="key-takeaways">
            <h3 class="key-takeaways-title">What you'll learn</h3>
            <ul>
              {keyTakeaways.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}

        <!-- Table of Contents -->
        {tocItems.length > 0 && (
          <div class="toc-box">
            <h3 class="toc-title">Table of Contents</h3>
            <ol class="toc-list">
              {tocItems.map((item) => (
                <li><a href={`#${item.id}`}>{item.label}</a></li>
              ))}
            </ol>
          </div>
        )}

        <!-- Main article content slot -->
        <div class="content">
          <slot />
        </div>

        <!-- People Also Ask -->
        {paaItems.length > 0 && (
          <section class="paa-section">
            <h2 class="paa-heading">People Also Ask</h2>
            <div class="paa-list">
              {paaItems.map((item) => (
                <div class="paa-item">
                  <p class="paa-question">{item.question}</p>
                  <p class="paa-answer">{item.answer}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Extended FAQ Accordion -->
        {extendedFaqItems.length > 0 && (
          <section class="faq-section" id="faq">
            <h2 class="faq-heading">Frequently Asked Questions</h2>
            <div class="faq-list">
              {extendedFaqItems.map((item) => (
                <details class="faq-item">
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- After-content slot (author bio, related articles, newsletter) -->
        <slot name="after-content" />

      </div>
    </div>

    <!-- Article Footer -->
    <footer class="article-footer">
      <div class="container">
        <a href="/blog" class="back-button">← Back to Blog</a>
      </div>
    </footer>
  </article>

  <Footer />
</Layout>

<style is:global>
  /* ─── Reset & Base ─── */
  .blog-post * { box-sizing: border-box; }
  .blog-post { background: #ffffff; min-height: 100vh; }
  html { scroll-behavior: smooth; }

  /* ─── Container ─── */
  .blog-post .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ─── Breadcrumb ─── */
  .breadcrumb-nav {
    padding: 14px 0;
    border-bottom: 1px solid #e5e7eb;
    background: #ffffff;
  }
  .breadcrumb-nav .container {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
  }
  .breadcrumb-nav a {
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb-nav a:hover { color: #111827; }
  .breadcrumb-nav span { color: #d1d5db; }
  .breadcrumb-current { color: #111827; font-weight: 500; }

  /* ─── Hero ─── */
  .hero-section { width: 100%; background: #f9fafb; overflow: hidden; }
  .hero-image {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    display: block;
  }

  /* ─── Article Header ─── */
  .article-header { padding: 48px 0 32px; background: #ffffff; }
  .category-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ffffff;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    padding: 6px 14px;
    border-radius: 6px;
    margin-bottom: 20px;
  }
  .article-title {
    font-size: 38px;
    font-weight: 800;
    line-height: 1.15;
    color: #0f172a;
    margin: 0 0 16px 0;
    letter-spacing: -0.03em;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .article-subtitle {
    font-size: 18px;
    line-height: 1.7;
    color: #4b5563;
    margin: 0 0 20px 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #6b7280;
    flex-wrap: wrap;
  }
  .article-meta .dot { color: #d1d5db; }

  /* ─── Article Content ─── */
  .article-content { padding: 32px 0 64px; background: #ffffff; }

  /* ─── Key Takeaways ─── */
  .key-takeaways {
    background: #f0f9ff;
    border: 1px solid #bae6fd;
    border-left: 4px solid #0284c7;
    border-radius: 0 8px 8px 0;
    padding: 24px 28px;
    margin-bottom: 32px;
  }
  .key-takeaways-title {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0369a1;
    margin: 0 0 14px 0;
  }
  .key-takeaways ul {
    margin: 0;
    padding-left: 20px;
  }
  .key-takeaways li {
    font-size: 15px;
    color: #0f172a;
    margin-bottom: 8px;
    line-height: 1.6;
  }
  .key-takeaways li:last-child { margin-bottom: 0; }

  /* ─── Table of Contents ─── */
  .toc-box {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 24px 28px;
    margin-bottom: 40px;
  }
  .toc-title {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #374151;
    margin: 0 0 14px 0;
  }
  .toc-list {
    margin: 0;
    padding-left: 20px;
  }
  .toc-list li {
    margin-bottom: 8px;
    line-height: 1.5;
  }
  .toc-list a {
    color: #2563eb;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .toc-list a:hover { color: #1d4ed8; text-decoration: underline; }

  /* ─── Main Content Typography ─── */
  .content {
    font-size: 17px;
    line-height: 1.8;
    color: #1f2937;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    letter-spacing: -0.01em;
  }

  .content p { margin: 0 0 24px 0; }

  .content h2 {
    font-size: 28px;
    font-weight: 800;
    line-height: 1.2;
    color: #0f172a;
    margin: 52px 0 16px 0;
    letter-spacing: -0.03em;
    scroll-margin-top: 24px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .content h2:first-child { margin-top: 0; }

  .content h3 {
    font-size: 21px;
    font-weight: 700;
    line-height: 1.3;
    color: #0f172a;
    margin: 36px 0 12px 0;
    letter-spacing: -0.02em;
    scroll-margin-top: 24px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .content h4 {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
    color: #1e293b;
    margin: 28px 0 10px 0;
    scroll-margin-top: 24px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .content ul, .content ol {
    margin: 0 0 24px 0;
    padding-left: 28px;
  }
  .content li { margin-bottom: 10px; line-height: 1.75; color: #4b5563; }

  .content strong { font-weight: 700; color: #111827; }
  .content em { font-style: italic; }

  .content a {
    color: #2563eb;
    text-decoration: underline;
    text-decoration-color: #93c5fd;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: all 0.2s;
  }
  .content a:hover { color: #1d4ed8; text-decoration-color: #2563eb; }

  .content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 32px 0;
  }

  .content blockquote {
    margin: 32px 0;
    padding: 24px 32px;
    background: #eff6ff;
    border-left: 4px solid #3b82f6;
    border-radius: 0 8px 8px 0;
  }
  .content blockquote p { margin: 0; font-size: 18px; line-height: 1.7; color: #1f2937; }

  /* ─── Tables ─── */
  .content table {
    width: 100% !important;
    border-collapse: separate !important;
    border-spacing: 0 !important;
    margin: 32px 0 !important;
    font-size: 15px !important;
    border-radius: 10px !important;
    overflow: hidden !important;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07) !important;
    border: 1px solid #e5e7eb !important;
  }
  .content thead { background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%) !important; }
  .content th {
    padding: 14px 18px !important;
    text-align: left !important;
    font-weight: 700 !important;
    color: #ffffff !important;
    font-size: 13px !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    border: none !important;
    background: transparent !important;
  }
  .content tbody tr:nth-child(odd) { background-color: #ffffff !important; }
  .content tbody tr:nth-child(even) { background-color: #f8fafc !important; }
  .content tbody tr:hover { background-color: #eef6ff !important; }
  .content td {
    padding: 13px 18px !important;
    border: none !important;
    border-bottom: 1px solid #e5e7eb !important;
    color: #374151 !important;
    line-height: 1.5 !important;
    background: transparent !important;
  }
  .content td:first-child { font-weight: 600 !important; color: #1f2937 !important; }
  .content tr:last-child td { border-bottom: none !important; }

  /* ─── People Also Ask ─── */
  .paa-section { margin: 56px 0 40px; }
  .paa-heading {
    font-size: 26px;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 20px 0;
    padding-bottom: 12px;
    border-bottom: 2px solid #e5e7eb;
    letter-spacing: -0.02em;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .paa-list { display: flex; flex-direction: column; gap: 10px; }
  .paa-item {
    background: #f8faff;
    border: 1px solid #dbeafe;
    border-left: 4px solid #2563eb;
    border-radius: 0 8px 8px 0;
    padding: 18px 20px;
    transition: background 0.2s;
  }
  .paa-item:hover { background: #eff6ff; }
  .paa-question {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 8px 0;
    line-height: 1.4;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .paa-answer {
    font-size: 15px;
    color: #4b5563;
    margin: 0;
    line-height: 1.7;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* ─── FAQ Accordion ─── */
  .faq-section { margin: 40px 0; }
  .faq-heading {
    font-size: 26px;
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 20px 0;
    padding-bottom: 12px;
    border-bottom: 2px solid #e5e7eb;
    letter-spacing: -0.02em;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .faq-list { display: flex; flex-direction: column; gap: 8px; }
  .faq-item {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    background: #ffffff;
  }
  .faq-item summary {
    padding: 16px 20px;
    font-size: 15px;
    font-weight: 600;
    color: #111827;
    background: #f9fafb;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.2s, color 0.2s;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    font-size: 22px;
    font-weight: 300;
    color: #6b7280;
    flex-shrink: 0;
    margin-left: 12px;
  }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item summary:hover { background: #f3f4f6; color: #2563eb; }
  .faq-item p {
    padding: 16px 20px;
    margin: 0;
    font-size: 15px;
    line-height: 1.75;
    color: #4b5563;
    border-top: 1px solid #e5e7eb;
    background: #ffffff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* ─── Article Footer ─── */
  .article-footer { padding: 32px 0 64px; border-top: 1px solid #e5e7eb; }
  .back-button {
    display: inline-flex;
    align-items: center;
    font-size: 15px;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    transition: color 0.2s;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .back-button:hover { color: #1d4ed8; }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .blog-post .container { padding: 0 20px; }
    .hero-image { max-height: 280px; }
    .article-header { padding: 32px 0 24px; }
    .article-title { font-size: 28px; }
    .article-subtitle { font-size: 16px; }
    .content { font-size: 16px; }
    .content h2 { font-size: 22px; margin: 40px 0 12px 0; }
    .content h3 { font-size: 19px; margin: 28px 0 10px 0; }
    .content h4 { font-size: 17px; }
    .content table {
      display: block !important;
      overflow-x: auto !important;
      -webkit-overflow-scrolling: touch !important;
    }
    .paa-heading, .faq-heading { font-size: 22px; }
  }
</style>
