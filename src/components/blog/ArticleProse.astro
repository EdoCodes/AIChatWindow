---
/**
 * Prose wrapper for blog article content.
 * Applies consistent typography and spacing.
 */
---

<div class="article-prose">
  <slot />
</div>

<style>
  .article-prose {
    @apply text-gray-700 leading-relaxed;
  }
  .article-prose :global(h2) {
    @apply text-3xl font-bold text-gray-900 mt-16 mb-6 scroll-mt-24;
  }
  .article-prose :global(h2:first-child) {
    @apply mt-0;
  }
  .article-prose :global(h3) {
    @apply text-xl font-bold text-gray-900 mt-10 mb-4;
  }
  .article-prose :global(h4) {
    @apply text-lg font-semibold text-gray-900 mt-6 mb-3;
  }
  .article-prose :global(p) {
    @apply mb-6;
  }
  .article-prose :global(ul),
  .article-prose :global(ol) {
    @apply mb-6 pl-6;
  }
  .article-prose :global(li) {
    @apply mb-2;
  }
  .article-prose :global(strong) {
    @apply font-semibold text-gray-900;
  }
  .article-prose :global(table) {
    @apply w-full mb-8 border-collapse;
  }
  .article-prose :global(th),
  .article-prose :global(td) {
    @apply border border-gray-300 px-4 py-3 text-left text-sm;
  }
  .article-prose :global(thead tr) {
    @apply bg-gray-50;
  }
  .article-prose :global(tbody tr:nth-child(even)) {
    @apply bg-gray-50/50;
  }
  .article-prose :global(a) {
    @apply text-primary-600 hover:text-primary-700 underline;
  }
</style>
