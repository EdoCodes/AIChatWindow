<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">From the Community</h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Discover the most popular AI chat tools and platforms used by millions worldwide. 
        From free alternatives to enterprise solutions.
      </p>
    </div>

    <!-- Filter Controls -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
      <!-- Category Tabs -->
      <div class="flex flex-wrap gap-2">
        <button class="px-6 py-3 bg-black text-white rounded-full text-sm font-medium transition-all duration-200 hover:bg-gray-800">
          All Tools (24)
        </button>
        <button class="px-6 py-3 bg-white text-gray-600 rounded-full text-sm font-medium hover:bg-gray-100 transition-all duration-200 border border-gray-200">
          Free Tools (12)
        </button>
        <button class="px-6 py-3 bg-white text-gray-600 rounded-full text-sm font-medium hover:bg-gray-100 transition-all duration-200 border border-gray-200">
          Premium (8)
        </button>
        <button class="px-6 py-3 bg-white text-gray-600 rounded-full text-sm font-medium hover:bg-gray-100 transition-all duration-200 border border-gray-200">
          Enterprise (4)
        </button>
      </div>
      
      <!-- Sort Dropdown -->
      <div class="flex items-center space-x-4">
        <span class="text-sm text-gray-500">Sort by:</span>
        <select class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-black focus:border-black">
          <option>Most Popular</option>
          <option>Recently Added</option>
          <option>Highest Rated</option>
          <option>Free First</option>
        </select>
      </div>
    </div>

    <!-- Featured Tools Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 mb-12">
      
