---
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">From the Community</h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Discover the most popular AI chat tools and platforms used by millions worldwide.
        From free alternatives to enterprise solutions.
      </p>
    </div>

    <!-- AI Tools Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

      <!-- ChatGPT -->
      <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="relative">
          <img src="https://images.pexels.com/photos/8386440/pexels-photo-8386440.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&fit=crop" alt="ChatGPT Interface" class="w-full h-64 object-cover">
        </div>
        <div class="p-6">
          <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide rounded-sm mb-3">
            Premium
          </span>
          <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight">
            ChatGPT: Complete Guide to OpenAI's Advanced AI Chatbot
          </h3>
          <p class="text-gray-600 text-sm mb-4 leading-relaxed">
            The most advanced AI chatbot with GPT-4 technology. Perfect for conversations, writing, coding, and creative tasks.
          </p>
          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <span>by OpenAI</span>
            <span>100M+ users</span>
          </div>
          <a href="https://chat.openai.com" target="_blank" class="inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors">
            Try Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>

      <!-- Claude -->
      <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="relative">
          <img src="https://images.pexels.com/photos/3861969/pexels-photo-3861969.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&fit=crop" alt="Claude AI Interface" class="w-full h-64 object-cover">
        </div>
        <div class="p-6">
          <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide rounded-sm mb-3">
            Premium
          </span>
          <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight">
            Claude: Anthropic's Constitutional AI Assistant
          </h3>
          <p class="text-gray-600 text-sm mb-4 leading-relaxed">
            Constitutional AI assistant focused on being helpful, harmless, and honest. Excellent for analysis and reasoning.
          </p>
          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <span>by Anthropic</span>
            <span>10M+ users</span>
          </div>
          <a href="https://claude.ai" target="_blank" class="inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors">
            Try Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>

      <!-- Google Bard -->
      <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="relative">
          <img src="https://images.pexels.com/photos/8386434/pexels-photo-8386434.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&fit=crop" alt="Google Bard Interface" class="w-full h-64 object-cover">
        </div>
        <div class="p-6">
          <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide rounded-sm mb-3">
            Free
          </span>
          <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight">
            Google Bard: AI-Powered Creative Assistant
          </h3>
          <p class="text-gray-600 text-sm mb-4 leading-relaxed">
            Google's experimental AI chatbot powered by LaMDA. Great for creative writing and brainstorming sessions.
          </p>
          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <span>by Google</span>
            <span>50M+ users</span>
          </div>
          <a href="https://bard.google.com" target="_blank" class="inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors">
            Try Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>

      <!-- Microsoft Copilot -->
      <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="relative">
          <img src="https://images.pexels.com/photos/590020/pexels-photo-590020.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&fit=crop" alt="Microsoft Copilot Interface" class="w-full h-64 object-cover">
        </div>
        <div class="p-6">
          <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide rounded-sm mb-3">
            Enterprise
          </span>
          <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight">
            Microsoft Copilot: AI-Powered Productivity
          </h3>
          <p class="text-gray-600 text-sm mb-4 leading-relaxed">
            AI-powered assistant integrated with Microsoft 365. Perfect for productivity and business workflows.
          </p>
          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <span>by Microsoft</span>
            <span>25M+ users</span>
          </div>
          <a href="https://copilot.microsoft.com" target="_blank" class="inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors">
            Try Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>

      <!-- Perplexity AI -->
      <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="relative">
          <img src="https://images.pexels.com/photos/8386440/pexels-photo-8386440.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&fit=crop" alt="Perplexity AI Interface" class="w-full h-64 object-cover">
        </div>
        <div class="p-6">
          <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide rounded-sm mb-3">
            Free
          </span>
          <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight">
            Perplexity AI: Search-Powered Answer Engine
          </h3>
          <p class="text-gray-600 text-sm mb-4 leading-relaxed">
            AI-powered search engine that provides accurate answers with real-time web sources and citations.
          </p>
          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <span>by Perplexity</span>
            <span>5M+ users</span>
          </div>
          <a href="https://perplexity.ai" target="_blank" class="inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors">
            Try Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>

      <!-- Character.AI -->
      <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="relative">
          <img src="https://images.pexels.com/photos/3861969/pexels-photo-3861969.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&fit=crop" alt="Character.AI Interface" class="w-full h-64 object-cover">
        </div>
        <div class="p-6">
          <span class="inline-block px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide rounded-sm mb-3">
            Free
          </span>
          <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight">
            Character.AI: Create and Chat with AI Characters
          </h3>
          <p class="text-gray-600 text-sm mb-4 leading-relaxed">
            Create and chat with AI characters. Perfect for creative writing, roleplay, and entertainment.
          </p>
          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <span>by Character.AI</span>
            <span>20M+ users</span>
          </div>
          <a href="https://character.ai" target="_blank" class="inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors">
            Try Now
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>

    </div>
  </div>
</section>
